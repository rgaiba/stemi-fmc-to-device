# raw data files — user uploads, not committed (only the metadata files in these folders are)
data/raw/**/*.csv
data/raw/**/*.txt
data/raw/**/*.zip
data/raw/**/*.shp
data/raw/**/*.shx
data/raw/**/*.dbf
data/raw/**/*.prj
data/raw/**/*.cpg
data/raw/**/*.xml
data/raw/**/*.parquet
data/raw/**/*.gz

# processed pipeline outputs (regeneratable)
data/processed/**/*.parquet
data/processed/**/*.csv
data/processed/**/*.json

# OSRM cache and large derived files
**/osrm_cache/

# python
__pycache__/
*.pyc
.venv/
venv/

# scratch outputs
outputs/**/scratch_*
